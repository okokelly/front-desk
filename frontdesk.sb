;; macOS sandbox profile for front desk
;; Usage: sandbox-exec -f frontdesk.sb /usr/bin/python3 frontdesk.py --port 8765
;;
;; This profile provides FILESYSTEM isolation only. With (allow default) below,
;; everything is permitted EXCEPT what we explicitly deny — namely the home
;; directory, re-allowing only:
;;   - The frontdesk directory (reading code + prompt, writing sessions)
;;   - The .env file (reading API key)
;;
;; It does NOT restrict network: the process can still reach any host, not just
;; api.deepseek.com. macOS sandbox can't filter outbound traffic by domain.
;;
;; Replace the paths below with your actual installation paths.

(version 1)
(allow default)

;; Block all access to home directory...
(deny file-read* (subpath "/Users/YOUR_USERNAME"))
(deny file-write* (subpath "/Users/YOUR_USERNAME"))

;; ...except exactly what the agent needs
(allow file-read* (subpath "/path/to/frontdesk"))
(allow file-read* (subpath "/Users/YOUR_USERNAME/.frontdesk/.env"))
(allow file-write* (subpath "/path/to/frontdesk/sessions"))
